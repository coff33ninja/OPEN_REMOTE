{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openremote.local/protocol/remote-layout.schema.json",
  "title": "OpenRemote remote layout",
  "type": "object",
  "required": [
    "id",
    "name",
    "layout"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "layout": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/control"
      }
    }
  },
  "$defs": {
    "control": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "button",
            "toggle",
            "slider",
            "touchpad",
            "text_input",
            "dpad",
            "grid_buttons",
            "macro_button"
          ]
        },
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "step": {
          "type": "number"
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
